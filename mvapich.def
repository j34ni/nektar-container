Bootstrap: docker
From: ubuntu:22.04

%post
    apt update -y
    DEBIAN_FRONTEND=noninteractive apt install -y --no-install-recommends ca-certificates tzdata wget
    apt clean

%environment
    export TZ="Europe/Oslo"
    export PATH="/opt/conda/bin:$PATH"

%post
    wget -q -nc --no-check-certificate -P /var/tmp https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh
    bash /var/tmp/Miniforge3-Linux-x86_64.sh -b -p /opt/conda
    rm /var/tmp/Miniforge3-Linux-x86_64.sh

%post
    . /opt/conda/etc/profile.d/conda.sh
    mamba install -y -c conda-forge nektar=5.9.0 micro mvapich=4.1 vim
    conda clean -afy

%files
    start.sh /opt/
